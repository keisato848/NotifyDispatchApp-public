<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="NotifyDispatchApp.SettingsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="設定"
    AutomationId="SettingsPageView"
    BackgroundColor="{StaticResource Background}">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">

            <!-- Header -->
            <Border StrokeShape="RoundRectangle 16" StrokeThickness="0"
                    BackgroundColor="{StaticResource Surface}" Padding="20,16">
                <Border.Shadow>
                    <Shadow Brush="{StaticResource BlackBrush}" Offset="0,2" Radius="8" Opacity="0.06" />
                </Border.Shadow>
                <HorizontalStackLayout Spacing="14">
                    <Border StrokeShape="RoundRectangle 14" StrokeThickness="0"
                            BackgroundColor="{StaticResource Gray100}"
                            HeightRequest="52" WidthRequest="52">
                        <Label Text="⚙️" FontSize="28" VerticalOptions="Center" HorizontalOptions="Center" />
                    </Border>
                    <VerticalStackLayout VerticalOptions="Center" Spacing="4">
                        <Label Text="アプリ設定" FontSize="20" FontAttributes="Bold" TextColor="{StaticResource Gray900}" />
                        <Label Text="通知や表示のカスタマイズ" FontSize="13" TextColor="{StaticResource Gray500}" />
                    </VerticalStackLayout>
                </HorizontalStackLayout>
            </Border>

            <!-- 通知設定 -->
            <Border StrokeShape="RoundRectangle 14" StrokeThickness="0"
                    BackgroundColor="{StaticResource Surface}" Padding="20">
                <Border.Shadow>
                    <Shadow Brush="{StaticResource BlackBrush}" Offset="0,1" Radius="6" Opacity="0.05" />
                </Border.Shadow>
                <VerticalStackLayout Spacing="16">
                    <Label Text="通知" FontSize="16" FontAttributes="Bold" TextColor="{StaticResource Gray900}" />
                    <Grid ColumnDefinitions="*,Auto">
                        <VerticalStackLayout>
                            <Label Text="プッシュ通知" FontSize="14" TextColor="{StaticResource Gray900}" />
                            <Label Text="新しい出動情報を通知で受信" FontSize="12" TextColor="{StaticResource Gray500}" />
                        </VerticalStackLayout>
                        <Switch Grid.Column="1" x:Name="switchPush" IsToggled="True"
                                OnColor="{StaticResource Tertiary}" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- 表示設定 -->
            <Border StrokeShape="RoundRectangle 14" StrokeThickness="0"
                    BackgroundColor="{StaticResource Surface}" Padding="20">
                <Border.Shadow>
                    <Shadow Brush="{StaticResource BlackBrush}" Offset="0,1" Radius="6" Opacity="0.05" />
                </Border.Shadow>
                <VerticalStackLayout Spacing="16">
                    <Label Text="表示" FontSize="16" FontAttributes="Bold" TextColor="{StaticResource Gray900}" />
                    <Grid ColumnDefinitions="*,Auto">
                        <VerticalStackLayout>
                            <Label Text="自動更新" FontSize="14" TextColor="{StaticResource Gray900}" />
                            <Label Text="30秒ごとにデータを自動更新" FontSize="12" TextColor="{StaticResource Gray500}" />
                        </VerticalStackLayout>
                        <Switch Grid.Column="1" x:Name="switchAutoRefresh" IsToggled="True"
                                OnColor="{StaticResource Tertiary}" Toggled="OnAutoRefreshToggled" />
                    </Grid>
                    <BoxView HeightRequest="1" Color="{StaticResource Gray200}" />
                    <VerticalStackLayout Spacing="6">
                        <Label Text="デフォルト地域" FontSize="14" TextColor="{StaticResource Gray900}" />
                        <Picker x:Name="pickerRegion" Title="地域を選択" SelectedIndexChanged="OnRegionChanged">
                            <Picker.Items>
                                <x:String>富山市</x:String>
                                <x:String>高岡市</x:String>
                                <x:String>射水市</x:String>
                                <x:String>氷見市</x:String>
                                <x:String>砺波市</x:String>
                                <x:String>小矢部市</x:String>
                                <x:String>南砺市</x:String>
                                <x:String>滑川市</x:String>
                                <x:String>黒部市</x:String>
                                <x:String>魚津市</x:String>
                            </Picker.Items>
                        </Picker>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!-- データ設定 -->
            <Border StrokeShape="RoundRectangle 14" StrokeThickness="0"
                    BackgroundColor="{StaticResource Surface}" Padding="20">
                <Border.Shadow>
                    <Shadow Brush="{StaticResource BlackBrush}" Offset="0,1" Radius="6" Opacity="0.05" />
                </Border.Shadow>
                <VerticalStackLayout Spacing="16">
                    <Label Text="データ表示" FontSize="16" FontAttributes="Bold" TextColor="{StaticResource Gray900}" />
                    <Label Text="表示件数を変更してもキャッシュには全件保持されます" FontSize="11" TextColor="{StaticResource Gray400}" />

                    <!-- 消防出動情報 表示件数 -->
                    <VerticalStackLayout Spacing="4">
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="🚒 消防出動情報" FontSize="14" TextColor="{StaticResource Gray900}" />
                            <Label Grid.Column="1" x:Name="lblDispatchCount" FontSize="14"
                                   FontAttributes="Bold" TextColor="{StaticResource Primary}" />
                        </Grid>
                        <Slider x:Name="sliderDispatchCount" Minimum="10" Maximum="100000"
                                ValueChanged="OnDispatchCountChanged"
                                MinimumTrackColor="{StaticResource Primary}"
                                MaximumTrackColor="{StaticResource Gray200}"
                                ThumbColor="{StaticResource Primary}" />
                    </VerticalStackLayout>

                    <BoxView HeightRequest="1" Color="{StaticResource Gray200}" />

                    <!-- 熊出没情報 表示件数 -->
                    <VerticalStackLayout Spacing="4">
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="🐻 熊出没情報" FontSize="14" TextColor="{StaticResource Gray900}" />
                            <Label Grid.Column="1" x:Name="lblBearCount" FontSize="14"
                                   FontAttributes="Bold" TextColor="{StaticResource Primary}" />
                        </Grid>
                        <Slider x:Name="sliderBearCount" Minimum="10" Maximum="100000"
                                ValueChanged="OnBearCountChanged"
                                MinimumTrackColor="{StaticResource Primary}"
                                MaximumTrackColor="{StaticResource Gray200}"
                                ThumbColor="{StaticResource Primary}" />
                    </VerticalStackLayout>

                    <BoxView HeightRequest="1" Color="{StaticResource Gray200}" />

                    <!-- キャッシュ情報と操作 -->
                    <Label x:Name="lblCacheInfo" Text="キャッシュ: 計算中..."
                           FontSize="12" TextColor="{StaticResource Gray500}" />

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                        <Button Text="📥 全件ダウンロード" FontSize="12" Padding="10,8"
                                BackgroundColor="{StaticResource Primary}" TextColor="White"
                                CornerRadius="10" x:Name="btnBulkDownload"
                                Clicked="OnBulkDownloadClicked" />
                        <Button Grid.Column="1" Text="🗑️ キャッシュ削除" FontSize="12" Padding="10,8"
                                BackgroundColor="{StaticResource Gray300}" TextColor="{StaticResource Gray700}"
                                CornerRadius="10" x:Name="btnClearCache"
                                Clicked="OnClearCacheClicked" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- アプリ情報 -->
            <Border StrokeShape="RoundRectangle 14" StrokeThickness="0"
                    BackgroundColor="{StaticResource Surface}" Padding="20">
                <Border.Shadow>
                    <Shadow Brush="{StaticResource BlackBrush}" Offset="0,1" Radius="6" Opacity="0.05" />
                </Border.Shadow>
                <VerticalStackLayout Spacing="12">
                    <Label Text="アプリ情報" FontSize="16" FontAttributes="Bold" TextColor="{StaticResource Gray900}" />
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Text="バージョン" FontSize="14" TextColor="{StaticResource Gray600}" />
                        <Label Grid.Column="1" Text="1.0.3" FontSize="14" TextColor="{StaticResource Gray400}" />
                    </Grid>
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Text="ビルド" FontSize="14" TextColor="{StaticResource Gray600}" />
                        <Label Grid.Column="1" Text="7" FontSize="14" TextColor="{StaticResource Gray400}" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
